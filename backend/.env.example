# Databricks SQL Warehouse connection settings
DATABRICKS_SERVER_HOSTNAME=dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
DATABRICKS_ACCESS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option A (recommended): full table path
DATABRICKS_TABLE=dis_pfc_con_gold_test.pbc_afh_contract

# Option B: use catalog+schema+table parts instead of DATABRICKS_TABLE
# DATABRICKS_CATALOG=dis_pfc_con_gold_test
# DATABRICKS_SCHEMA=default
# DATABRICKS_TABLE_NAME=pbc_afh_contract

# Flask runtime
PORT=5000
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0

# AI assistant (OpenAI)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-mini
# Optional (advanced): custom API base and timeout
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=45
